# ═══════════════════════════════════════════════════════
#  DW SciOly Hub — Environment Variables
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# App mode: "prototype" (mock data) or "production" (Supabase)
VITE_MODE=prototype

# Supabase (only needed in production mode)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Feature flag overrides (set to "true" to enable individually)
# VITE_FLAG_REAL_AUTH=false
# VITE_FLAG_REAL_DATA=false
# VITE_FLAG_AI_QUIZZES=false
# VITE_FLAG_AI_TEST_ANALYSIS=false
# VITE_FLAG_REALTIME=false
# VITE_FLAG_PWA=false

# These are used in Edge Functions (set via Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ANTHROPIC_API_KEY=your-claude-api-key
# RESEND_API_KEY=your-resend-api-key
# INVITE_REDIRECT_URL=https://your-app.vercel.app/app
